# LLM Configuration
LLM_PROVIDER=groq            # groq | openai | gemini | ollama
GROQ_API_KEY=gsk_...         # Groq API key (primary)
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API Configuration
API_CORS_ORIGINS=http://localhost:3000,https://yourapp.vercel.app
TOP_N_CANDIDATES=15

# Cache (Phase 7 — optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
